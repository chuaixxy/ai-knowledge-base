# ──── LLM Providers ────────────────────────────────────────────────
LLM_PROVIDER=deepseek
# 可选: deepseek | qwen | openai

# 统一 API Key（优先级低于各提供商专属 Key）
API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=
# https://platform.deepseek.com/api_keys

# Qwen (Tongyi / 阿里云百炼)
QWEN_API_KEY=
# https://bailian.console.aliyun.com

# OpenAI
OPENAI_API_KEY=
# https://platform.openai.com/api-keys

# ──── LLM Runtime ───────────────────────────────────────────────────
# 模型名称（留空使用各提供商默认模型）
LLM_MODEL=

# 请求超时（秒）
LLM_TIMEOUT=60

# 失败重试次数
LLM_MAX_RETRIES=3

# 调试日志：设为 1 开启
LLM_DEBUG=0

# ──── 飞书推送（distribution/publisher.ts）────────────────────────────
# 群自定义机器人 Webhook（必需）
FEISHU_WEBHOOK_URL=
# https://open.feishu.cn/document/client-docs/bot-v3/add-custom-bot

# 签名校验密钥（可选；机器人在飞书侧开启「签名校验」时填写）
FEISHU_WEBHOOK_SECRET=

# 自定义关键词（可选；机器人开启「自定义关键词」时填写，会自动写入 title/text）
FEISHU_KEYWORD=

# 飞书 Webhook 限制：5 次/秒、100 次/分钟、请求体 ≤ 20 KB
# IP 白名单请在飞书机器人设置中配置，无需写入 .env
