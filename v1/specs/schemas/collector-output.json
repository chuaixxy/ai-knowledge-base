{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "collector-output",
  "title": "Collector Output",
  "description": "knowledge/raw/{source}_{date}.json 的格式契约，由 collector agent 写入",
  "type": "object",
  "required": ["source", "collected_at", "items"],
  "additionalProperties": false,
  "properties": {
    "source": {
      "type": "string",
      "enum": ["github_trending", "hacker_news", "juejin", "wechat"],
      "description": "数据来源标识"
    },
    "collected_at": {
      "type": "string",
      "format": "date-time",
      "description": "采集时间，ISO 8601，如 2026-05-20T00:00:00Z"
    },
    "items": {
      "type": "array",
      "minItems": 15,
      "description": "采集条目列表，按 stars 从高到低排序",
      "items": { "$ref": "#/$defs/RawItem" }
    }
  },
  "$defs": {
    "RawItem": {
      "type": "object",
      "required": ["id", "title", "source_url", "source", "topic", "stars", "summary", "collected_at"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "条目唯一 ID，如 gh_spec_kit_001"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "条目标题"
        },
        "source_url": {
          "type": "string",
          "format": "uri",
          "description": "原文链接"
        },
        "source": {
          "type": "string",
          "enum": ["github_trending", "hacker_news", "juejin", "wechat"],
          "description": "数据来源，与顶层 source 一致"
        },
        "topic": {
          "type": "string",
          "enum": ["ai", "frontend"],
          "description": "内容主题，仅允许 ai 或 frontend"
        },
        "stars": {
          "type": "integer",
          "minimum": 0,
          "description": "热度数值：GitHub Trending 用当日新增 stars，HN 用 points，掘金用点赞数，微信用阅读量"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "中文摘要，50-100 字，基于实际抓取内容提炼，不编造"
        },
        "description": {
          "type": "string",
          "description": "英文原文描述（仅 github_trending 来源含此字段）"
        },
        "collected_at": {
          "type": "string",
          "format": "date-time",
          "description": "该条目采集时间，ISO 8601"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "原始标签（可选）"
        },
        "metadata": {
          "type": "object",
          "description": "扩展字段，如 stars、language、hn_points 等"
        }
      }
    }
  }
}
