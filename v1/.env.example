# ──── LLM Providers ────────────────────────────────────────────────
LLM_PROVIDER=deepseek
# 可选: deepseek | qwen | openai

# 统一 API Key（优先级低于各提供商专属 Key）
API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=
# https://platform.deepseek.com/api_keys

# Qwen (Tongyi / 阿里云百炼)
QWEN_API_KEY=
# https://bailian.console.aliyun.com

# OpenAI
OPENAI_API_KEY=
# https://platform.openai.com/api-keys

# ──── LLM Runtime ───────────────────────────────────────────────────
# 模型名称（留空使用各提供商默认模型）
LLM_MODEL=

# 请求超时（秒）
LLM_TIMEOUT=60

# 失败重试次数
LLM_MAX_RETRIES=3

# 调试日志：设为 1 开启
LLM_DEBUG=0
