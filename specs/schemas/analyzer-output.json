{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "analyzer-output",
  "title": "Analyzer Output",
  "description": "knowledge/articles/{id}.json 的格式契约，由 analyzer agent 写入，在 collector RawItem 基础上补充分析字段",
  "type": "object",
  "required": [
    "id", "title", "source", "source_url", "topic", "popularity",
    "summary", "tags", "collected_at", "highlights", "score", "analyzed_at", "status"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "全局唯一 ID，继承自 collector，如 gh_spec_kit_001"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "继承自 collector，不修改"
    },
    "source": {
      "type": "string",
      "enum": ["github_trending", "hacker_news", "juejin", "wechat"],
      "description": "继承自 collector，不修改"
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "继承自 collector，不修改"
    },
    "topic": {
      "type": "string",
      "enum": ["ai", "frontend"],
      "description": "继承自 collector，不修改"
    },
    "popularity": {
      "type": "integer",
      "minimum": 0,
      "description": "继承自 collector，不修改"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "在原始摘要基础上精炼，50-150 字，中文，不编造"
    },
    "tags": {
      "type": "array",
      "minItems": 2,
      "maxItems": 5,
      "description": "继承并补充，覆盖技术栈 / 主题 / 类型三维，2-5 个",
      "items": { "type": "string", "minLength": 1 }
    },
    "collected_at": {
      "type": "string",
      "format": "date-time",
      "description": "继承自 collector，不修改"
    },
    "highlights": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "description": "2-3 条核心亮点，说明为什么值得关注，每条不超过 30 字",
      "items": {
        "type": "string",
        "maxLength": 30
      }
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "相关性评分 0-1，对应 AGENTS.md 定义（0.9+ 改变格局 / 0.7-0.9 直接有帮助 / 0.5-0.7 值得了解 / <0.5 可略过）"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewed", "published", "archived"],
      "description": "生命周期状态，analyzer 写入时固定为 draft"
    },
    "analyzed_at": {
      "type": "string",
      "format": "date-time",
      "description": "分析完成时间，ISO 8601"
    },
    "raw_ref": {
      "type": "string",
      "description": "指向 knowledge/raw/ 中原始文件的相对路径，可选"
    },
    "metadata": {
      "type": "object",
      "description": "继承自 collector 的扩展字段，不修改"
    }
  }
}
